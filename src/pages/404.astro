---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404">
  <section class="fullscreen" style="background-image:url('/img/404-bg.jpg')">
    <div class="fs-mask"></div>
    <div class="fs-inner">
      <h1>404</h1>
      <p>Không tìm thấy trang rồi 🙊</p>
      <a class="fs-link" href="/">← Về trang chủ</a>
    </div>
  </section>
</BaseLayout>

<style>
  .fullscreen {
    position: relative;
    min-height: 100vh;
    background-color: #808080;
    background-position: center;
    background-size: cover;
    display: grid;
    place-items: center;
  }
  .fs-mask {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }
  .fs-inner {
    position: relative;
    text-align: center;
    color: #fff;
    padding: 1.5rem;
  }
  .fs-inner h1 {
    font-size: 72px;
    margin: 0;
  }
  .fs-inner p {
    font-size: 20px;
    font-weight: 300;
    margin: 0.5rem 0 1.5rem;
  }
  .fs-link {
    display: inline-block;
    color: #fff;
    text-transform: uppercase;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 1px;
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 999px;
    padding: 8px 20px;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }
  .fs-link:hover {
    background: #fff;
    color: var(--color-ink);
  }
</style>
