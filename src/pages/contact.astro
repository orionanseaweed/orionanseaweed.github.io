---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="Contact" description="Cách để kết nối với mình.">
  <Hero title="Contact" />

  <section class="page-column contact">
    <p>You can get in touch via email or find me at some of my favorite spots.</p>

    <ul class="contact-list">
      <li>
        <strong>Email:</strong>
        <a href="mailto:hxtunq@gmail.com">hxtunq@gmail.com</a> |
        <a href="mailto:concealedcharacterx@gmail.com">concealedcharacterx@gmail.com</a>
      </li>
      <li>
        <strong>Place:</strong> Hanoi University of Science and Technology | Other recommended
        <a href="https://maps.app.goo.gl/UmcaU3WdBH1uFqth8" target="_blank" rel="noopener noreferrer"
          >locations</a
        >.
      </li>
    </ul>

    <p>Here's my usual availability if you'd like to meet or hang out:</p>

    <div class="calendar-embed">
      <iframe
        title="Tung's Availability"
        src="https://calendar.google.com/calendar/embed?height=600&wkst=2&ctz=Asia%2FHo_Chi_Minh&showPrint=0&title=Tung's%20Availability&showTabs=0&showCalendars=0&src=bHZya3FwOGs0dGQzaGZvcnFxamdoZGFpb3NAZ3JvdXAuY2FsZW5kYXIuZ29vZ2xlLmNvbQ&src=Z2RobmZudjBscHMxcm00dWxuODR1aW84dDhAZ3JvdXAuY2FsZW5kYXIuZ29vZ2xlLmNvbQ&src=YW50am5ndjRhbjgwZTRkMzV1ZjNqOG80dmdAZ3JvdXAuY2FsZW5kYXIuZ29vZ2xlLmNvbQ&src=YjVydnNqaXFhNGpra3ZnODkxYmNocjN0MjhAZ3JvdXAuY2FsZW5kYXIuZ29vZ2xlLmNvbQ&color=%23928daf&color=%2395b9cc&color=%23c69080&color=%23ccb9a3"
        loading="lazy"></iframe>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-list {
    margin: 1rem 0 1.5rem;
    padding-left: 1.4rem;
  }
  .contact-list li {
    margin: 0.6rem 0;
    line-height: 1.7;
  }
  .calendar-embed {
    margin-top: 1rem;
  }
  .calendar-embed iframe {
    width: 100%;
    max-width: 800px;
    height: 400px;
    border: solid 1px #777;
    border-radius: 8px;
  }
</style>
