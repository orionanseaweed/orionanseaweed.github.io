---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { SITE } from '../consts';
---

<BaseLayout>
  <Hero title={SITE.title} image="/img/home-bg.jpg" big />

  <section class="about">
    <div class="about-text">
      <p>
        Xin chào. <br />
      </p>
    </div>

    <aside class="about-social">
      <h5 class="about-social-title">Social Media</h5>
      <SocialLinks />
    </aside>
  </section>
</BaseLayout>

<style>
  .about {
    max-width: 60rem;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 3.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .about {
      grid-template-columns: minmax(0, 1fr) 210px;
      gap: 3rem;
      align-items: start;
    }
  }

  .about-text p {
    margin: 1.4rem 0;
  }
  .about-text p:first-child {
    margin-top: 0;
  }
  .about-text a {
    color: var(--color-link);
    transition: color 0.2s ease;
  }
  .about-text a:hover,
  .about-text a:focus {
    color: var(--color-link-dark);
    text-decoration: underline;
  }

  .about-social-title {
    margin: 0 0 1rem;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-muted);
    font-weight: 700;
  }
  @media (min-width: 768px) {
    .about-social {
      border-left: 1px solid #eee;
      padding-left: 2rem;
    }
    .about-social-title {
      padding-top: 0.2rem;
    }
  }
</style>
